<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Charge Type List ─────────────────────────────────────────── -->
    <record id="view_pms_charge_type_list" model="ir.ui.view">
        <field name="name">pms.charge.type.list</field>
        <field name="model">pms.charge.type</field>
        <field name="arch" type="xml">
            <list string="Charge Types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_revenue" widget="boolean_toggle"/>
                <field name="is_tax" widget="boolean_toggle"/>
                <field name="is_expense" widget="boolean_toggle"/>
                <field name="is_refund" widget="boolean_toggle"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ─── Charge Type Form ─────────────────────────────────────────── -->
    <record id="view_pms_charge_type_form" model="ir.ui.view">
        <field name="name">pms.charge.type.form</field>
        <field name="model">pms.charge.type</field>
        <field name="arch" type="xml">
            <form string="Charge Type">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Rent, Cleaning Fee, OTA Commission"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="e.g. RENT, CLEANING"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="is_revenue"/>
                            <field name="is_tax"/>
                            <field name="is_expense"/>
                            <field name="is_refund"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Mapping" name="product_mapping">
                            <field name="product_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="default_code"/>
                                    <field name="list_price"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" nolabel="1" colspan="2"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── Charge Type Search ───────────────────────────────────────── -->
    <record id="view_pms_charge_type_search" model="ir.ui.view">
        <field name="name">pms.charge.type.search</field>
        <field name="model">pms.charge.type</field>
        <field name="arch" type="xml">
            <search string="Search Charge Types">
                <field name="name"/>
                <field name="code"/>
                <separator/>
                <filter string="Revenue" name="is_revenue" domain="[('is_revenue', '=', True)]"/>
                <filter string="Tax" name="is_tax" domain="[('is_tax', '=', True)]"/>
                <filter string="Expense" name="is_expense" domain="[('is_expense', '=', True)]"/>
                <filter string="Refund" name="is_refund" domain="[('is_refund', '=', True)]"/>
                <separator/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ─── Action ────────────────────────────────────────────────────── -->
    <record id="action_pms_charge_type" model="ir.actions.act_window">
        <field name="name">Charge Types</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">pms.charge.type</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_charge_type_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Charge Type!
            </p>
            <p>
                Charge Types define how reservation charges are categorized and allocated
                between owners, managers, and liabilities.
            </p>
        </field>
    </record>

    <!-- ─── Menu ──────────────────────────────────────────────────────── -->
    <menuitem id="menu_pms_charge_type"
              name="Charge Types"
              parent="menu_pms_config_cat"
              action="action_pms_charge_type"
              sequence="20"/>

</odoo>