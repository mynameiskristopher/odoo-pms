<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_pms_property_tree" model="ir.ui.view">
        <name>pms.property.tree</name>
        <model>pms.property</model>
        <arch type="xml">
            <tree string="Properties">
                <field name="name"/>
                <field name="property_type"/>
                <field name="max_occupancy"/>
                <field name="number_of_rooms"/>
                <field name="checkin_time" widget="float_time"/>
                <field name="checkout_time" widget="float_time"/>
                <field name="pets_allowed"/>
                <field name="list_price" string="Rent Price"/>
            </tree>
        </arch>
    </record>

    <!-- Form View -->
    <record id="view_pms_property_form" model="ir.ui.view">
        <name>pms.property.form</name>
        <model>pms.property</model>
        <arch type="xml">
            <form string="Property">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Cozy Beachfront Villa"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Property Specifications">
                            <field name="property_type"/>
                            <field name="number_of_rooms"/>
                            <field name="max_occupancy"/>
                            <field name="pets_allowed"/>
                        </group>
                        <group string="Logistics &amp; Location">
                            <field name="checkin_time" widget="float_time"/>
                            <field name="checkout_time" widget="float_time"/>
                            <label for="latitude" string="Geo Coordinates"/>
                            <div class="o_row">
                                <span>Lat:</span>
                                <field name="latitude" class="oe_inline"/>
                                <span>Long:</span>
                                <field name="longitude" class="oe_inline"/>
                            </div>
                            <field name="list_price" string="Default Daily Rent"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Provide a detailed description of the vacation rental..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </arch>
    </record>

    <!-- Search View -->
    <record id="view_pms_property_search" model="ir.ui.view">
        <name>pms.property.search</name>
        <model>pms.property</model>
        <arch type="xml">
            <search string="Search Properties">
                <field name="name"/>
                <field name="property_type"/>
                <filter string="Allows Pets" name="pets_allowed" domain="[('pets_allowed', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Property Type" name="group_by_type" context="{'group_by': 'property_type'}"/>
                </group>
            </search>
        </arch>
    </record>

    <!-- Action -->
    <record id="action_pms_property" model="ir.actions.act_window">
        <name>Properties</name>
        <type>ir.actions.act_window</type>
        <res_model>pms.property</res_model>
        <view_mode>tree,form</view_mode>
        <search_view_id ref="view_pms_property_search"/>
        <help type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Vacation Rental Property!
            </p>
            <p>
                Manage check-in times, room layouts, and occupancy settings for vacation rentals.
            </p>
        </help>
    </record>

    <!-- Menu Structure -->
    <!-- Top-Level Menu -->
    <menuitem id="menu_pms_root"
              name="Property Management"
              sequence="10"/>

    <!-- Configuration/Operations category -->
    <menuitem id="menu_pms_properties_cat"
              name="Properties"
              parent="menu_pms_root"
              sequence="10"/>

    <!-- Action menu item -->
    <menuitem id="menu_pms_property"
              name="Vacation Rentals"
              parent="menu_pms_properties_cat"
              action="action_pms_property"
              sequence="10"/>

</odoo>
