<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_pms_property_list" model="ir.ui.view">
        <field name="name">pms.property.list</field>
        <field name="model">pms.property</field>
        <field name="arch" type="xml">
            <list string="Properties">
                <field name="name"/>
                <field name="property_type"/>
                <field name="max_occupancy"/>
                <field name="number_of_rooms"/>
                <field name="number_of_floors"/>
                <field name="square_footage"/>
                <field name="checkin_time" widget="float_time"/>
                <field name="checkout_time" widget="float_time"/>
                <field name="pets_allowed"/>
                <field name="list_price" string="Rent Price"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_pms_property_form" model="ir.ui.view">
        <field name="name">pms.property.form</field>
        <field name="model">pms.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Cozy Beachfront Villa"/>
                        </h1>
                        <h2>
                            <field name="headline" placeholder="e.g. Beautiful beachfront condo with stunning sunset views"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Property Specifications">
                            <field name="property_type"/>
                            <field name="short_name" placeholder="e.g. Beachfront Villa"/>
                            <field name="unit_code" placeholder="e.g. VILLA-A"/>
                            <field name="number_of_rooms"/>
                            <field name="bedrooms"/>
                            <field name="number_of_floors"/>
                            <field name="square_footage"/>
                            <field name="max_occupancy"/>
                            <field name="pets_allowed"/>
                            <label for="full_bathrooms" string="Bathrooms"/>
                            <div class="o_row">
                                <span>Full:</span>
                                <field name="full_bathrooms" class="oe_inline"/>
                                <span>3/4:</span>
                                <field name="three_quarter_bathrooms" class="oe_inline"/>
                                <span>Half:</span>
                                <field name="half_bathrooms" class="oe_inline"/>
                            </div>
                        </group>
                        <group string="Logistics &amp; Rent">
                            <field name="checkin_time" widget="float_time"/>
                            <field name="checkout_time" widget="float_time"/>
                            <field name="list_price" string="Default Daily Rent"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <group>
                                <field name="short_description" placeholder="A short teaser/summary of the property..."/>
                                <field name="description" placeholder="Provide a detailed description of the vacation rental..."/>
                            </group>
                        </page>
                        <page string="Ownership" name="ownership">
                            <field name="unit_owner_ids">
                                <list editable="bottom" string="Owners">
                                    <field name="owner_id"/>
                                    <field name="contract_id"/>
                                    <field name="contract_type"/>
                                    <field name="tax_mode"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Location &amp; Compliance" name="location_compliance">
                            <group>
                                <group string="Address">
                                    <field name="street" placeholder="Street Address..."/>
                                    <field name="street2" placeholder="Extended Address..."/>
                                    <field name="city" placeholder="City"/>
                                    <field name="state_id" options="{'no_open': True, 'no_quick_create': True}"/>
                                    <field name="zip" placeholder="Postal Code"/>
                                    <field name="country_id" options="{'no_open': True, 'no_quick_create': True}"/>
                                </group>
                                <group string="Coordinates &amp; Compliance">
                                    <label for="latitude" string="Geo Coordinates"/>
                                    <div class="o_row">
                                        <span>Lat:</span>
                                        <field name="latitude" class="oe_inline"/>
                                        <span>Long:</span>
                                        <field name="longitude" class="oe_inline"/>
                                    </div>
                                    <field name="municipality_id" placeholder="STR License / Permit ID..."/>
                                </group>
                            </group>
                            <group string="Check-in Directions">
                                <field name="directions" placeholder="Driving directions, access codes, entry instructions..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_pms_property_search" model="ir.ui.view">
        <field name="name">pms.property.search</field>
        <field name="model">pms.property</field>
        <field name="arch" type="xml">
            <search string="Search Properties">
                <field name="name"/>
                <field name="property_type"/>
                <filter string="Allows Pets" name="pets_allowed" domain="[('pets_allowed', '=', True)]"/>
                <group>
                    <filter string="Property Type" name="group_by_type" context="{'group_by': 'property_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pms_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">pms.property</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_property_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Vacation Rental Property!
            </p>
            <p>
                Manage check-in times, room layouts, and occupancy settings for vacation rentals.
            </p>
        </field>
    </record>

    <!-- Menu Structure -->
    <!-- Top-Level Menu -->
    <menuitem id="menu_pms_root"
              name="Property Management"
              sequence="10"/>

    <!-- Configuration/Operations category -->
    <menuitem id="menu_pms_properties_cat"
              name="Properties"
              parent="menu_pms_root"
              sequence="10"/>

    <!-- Action menu item -->
    <menuitem id="menu_pms_property"
              name="Vacation Rentals"
              parent="menu_pms_properties_cat"
              action="action_pms_property"
              sequence="10"/>

</odoo>
