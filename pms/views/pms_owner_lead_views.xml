<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Lead Tag Views ───────────────────────────────────────────── -->
    <record id="view_pms_owner_lead_tag_list" model="ir.ui.view">
        <field name="name">pms.owner.lead.tag.list</field>
        <field name="model">pms.owner.lead.tag</field>
        <field name="arch" type="xml">
            <list string="Lead Tags">
                <field name="name"/>
                <field name="color"/>
            </list>
        </field>
    </record>

    <record id="view_pms_owner_lead_tag_form" model="ir.ui.view">
        <field name="name">pms.owner.lead.tag.form</field>
        <field name="model">pms.owner.lead.tag</field>
        <field name="arch" type="xml">
            <form string="Lead Tag">
                <group>
                    <field name="name"/>
                    <field name="color"/>
                </group>
            </form>
        </field>
    </record>

    <!-- ─── Stage Views ──────────────────────────────────────────────── -->
    <record id="view_pms_owner_lead_stage_list" model="ir.ui.view">
        <field name="name">pms.owner.lead.stage.list</field>
        <field name="model">pms.owner.lead.stage</field>
        <field name="arch" type="xml">
            <list string="Stages">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_won"/>
                <field name="is_lost"/>
                <field name="fold"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_pms_owner_lead_stage_form" model="ir.ui.view">
        <field name="name">pms.owner.lead.stage.form</field>
        <field name="model">pms.owner.lead.stage</field>
        <field name="arch" type="xml">
            <form string="Stage">
                <group>
                    <field name="name"/>
                    <field name="sequence"/>
                    <field name="is_won"/>
                    <field name="is_lost"/>
                    <field name="fold"/>
                    <field name="active"/>
                </group>
            </form>
        </field>
    </record>

    <!-- ─── Lead Kanban (Pipeline) View ──────────────────────────────── -->
    <record id="view_pms_owner_lead_kanban" model="ir.ui.view">
        <field name="name">pms.owner.lead.kanban</field>
        <field name="model">pms.owner.lead</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column"
                    sample="1">
                <field name="stage_id"/>
                <field name="priority"/>
                <field name="kanban_state"/>
                <field name="color"/>
                <field name="user_id"/>
                <field name="date_deadline"/>
                <field name="expected_monthly_revenue"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="oe_kanban_details">
                                <div>
                                    <field name="partner_id"/>
                                </div>
                                <div>
                                    <field name="owner_id"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="tag_ids" widget="many2many_tags"
                                               options="{'color_field': 'color'}"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="kanban_state" widget="state_selection"/>
                                        <field name="user_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                                <div t-if="record.expected_monthly_revenue.raw_value"
                                     class="text-muted">
                                    <field name="expected_monthly_revenue"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <span> / month</span>
                                </div>
                                <div t-if="record.date_deadline.raw_value"
                                     class="text-muted">
                                    <span class="fa fa-clock-o"/>
                                    <field name="date_deadline"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ─── Lead List View ───────────────────────────────────────────── -->
    <record id="view_pms_owner_lead_list" model="ir.ui.view">
        <field name="name">pms.owner.lead.list</field>
        <field name="model">pms.owner.lead</field>
        <field name="arch" type="xml">
            <list string="Owner Leads" decoration-muted="active == False">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="owner_id"/>
                <field name="stage_id"/>
                <field name="user_id"/>
                <field name="expected_property_count"/>
                <field name="expected_monthly_revenue" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="date_deadline"/>
                <field name="date_opened"/>
                <field name="date_closed"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ─── Lead Form View ───────────────────────────────────────────── -->
    <record id="view_pms_owner_lead_form" model="ir.ui.view">
        <field name="name">pms.owner.lead.form</field>
        <field name="model">pms.owner.lead</field>
        <field name="arch" type="xml">
            <form string="Owner Lead">
                <header>
                    <button name="action_won" type="object" string="Onboarded"
                            class="oe_highlight" invisible="stage_id.is_won"/>
                    <button name="action_lost" type="object" string="Lost"
                            invisible="stage_id.is_lost"/>
                    <field name="stage_id" widget="statusbar"
                           options="{'foldable': True}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_owner" type="object"
                                class="oe_stat_button" icon="fa-user"
                                invisible="not owner_id">
                            <span class="o_stat_text">Owner</span>
                        </button>
                        <button name="action_open_partner" type="object"
                                class="oe_stat_button" icon="fa-address-card"
                                invisible="not partner_id">
                            <span class="o_stat_text">Contact</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Onboard Acme Properties"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="owner_id"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="expected_property_count"/>
                            <field name="expected_monthly_revenue" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="date_deadline"/>
                        </group>
                    </group>
                    <group>
                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="description" nolabel="1" colspan="2"
                                   placeholder="Add notes about this owner opportunity…"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── Lead Search View ─────────────────────────────────────────── -->
    <record id="view_pms_owner_lead_search" model="ir.ui.view">
        <field name="name">pms.owner.lead.search</field>
        <field name="model">pms.owner.lead</field>
        <field name="arch" type="xml">
            <search string="Search Owner Leads">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="owner_id"/>
                <field name="user_id"/>
                <separator/>
                <filter string="My Leads" name="my_leads"
                        domain="[('user_id', '=', uid)]"/>
                <filter string="Active" name="active"
                        domain="[('active', '=', True)]"/>
                <separator/>
                <filter string="Won" name="won"
                        domain="[('stage_id.is_won', '=', True)]"/>
                <filter string="Lost" name="lost"
                        domain="[('stage_id.is_lost', '=', True)]"/>
                <separator/>
                <filter string="Stage" name="group_by_stage"
                        context="{'group_by': 'stage_id'}"/>
                <filter string="Assigned To" name="group_by_user"
                        context="{'group_by': 'user_id'}"/>
            </search>
        </field>
    </record>

    <!-- ─── Actions ──────────────────────────────────────────────────── -->
    <record id="action_pms_owner_lead" model="ir.actions.act_window">
        <field name="name">Owner Pipeline</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">pms.owner.lead</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_pms_owner_lead_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first owner pipeline opportunity!
            </p>
            <p>
                Track owner onboarding and relationship opportunities through
                a dedicated pipeline — separate from the sales CRM.
            </p>
        </field>
    </record>

    <record id="action_pms_owner_lead_stage" model="ir.actions.act_window">
        <field name="name">Pipeline Stages</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">pms.owner.lead.stage</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_pms_owner_lead_tag" model="ir.actions.act_window">
        <field name="name">Lead Tags</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">pms.owner.lead.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ─── Menu Items ────────────────────────────────────────────────── -->
    <menuitem id="menu_pms_owner_pipeline"
              name="Owner Pipeline"
              parent="menu_pms_owners_cat"
              action="action_pms_owner_lead"
              sequence="15"/>

    <menuitem id="menu_pms_owner_lead_config"
              name="Configuration"
              parent="menu_pms_owners_cat"
              sequence="90"/>

    <menuitem id="menu_pms_owner_lead_stage"
              name="Pipeline Stages"
              parent="menu_pms_owner_lead_config"
              action="action_pms_owner_lead_stage"
              sequence="10"/>

    <menuitem id="menu_pms_owner_lead_tag"
              name="Lead Tags"
              parent="menu_pms_owner_lead_config"
              action="action_pms_owner_lead_tag"
              sequence="20"/>

</odoo>