<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Reservation Charge List ───────────────────────────────────── -->
    <record id="view_pms_reservation_charge_list" model="ir.ui.view">
        <field name="name">pms.reservation.charge.list</field>
        <field name="model">pms.reservation.charge</field>
        <field name="arch" type="xml">
            <list string="Reservation Charges">
                <field name="transaction_date"/>
                <field name="reservation_id"/>
                <field name="charge_type_id"/>
                <field name="description"/>
                <field name="quantity"/>
                <field name="unit_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="gross_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="tax_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="net_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="source_system"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ─── Reservation Charge Form ───────────────────────────────────── -->
    <record id="view_pms_reservation_charge_form" model="ir.ui.view">
        <field name="name">pms.reservation.charge.form</field>
        <field name="model">pms.reservation.charge</field>
        <field name="arch" type="xml">
            <form string="Reservation Charge">
                <sheet>
                    <group>
                        <group>
                            <field name="reservation_id"/>
                            <field name="charge_type_id"/>
                            <field name="description"/>
                            <field name="transaction_date"/>
                        </group>
                        <group>
                            <field name="quantity"/>
                            <field name="unit_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="tax_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="gross_amount" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                            <field name="net_amount" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Source &amp; Reversal" name="source">
                            <group>
                                <group>
                                    <field name="source_system"/>
                                    <field name="source_reference"/>
                                </group>
                                <group>
                                    <field name="reversal_of_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Taxes" name="taxes">
                            <field name="tax_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── Reservation Charge Search ─────────────────────────────────── -->
    <record id="view_pms_reservation_charge_search" model="ir.ui.view">
        <field name="name">pms.reservation.charge.search</field>
        <field name="model">pms.reservation.charge</field>
        <field name="arch" type="xml">
            <search string="Search Reservation Charges">
                <field name="reservation_id"/>
                <field name="charge_type_id"/>
                <field name="source_system"/>
                <field name="transaction_date"/>
                <separator/>
                <filter string="Refunds" name="refunds" domain="[('reversal_of_id', '!=', False)]"/>
                <separator/>
                <filter string="Charge Type" name="group_by_charge_type" context="{'group_by': 'charge_type_id'}"/>
                <filter string="Reservation" name="group_by_reservation" context="{'group_by': 'reservation_id'}"/>
                <filter string="Source System" name="group_by_source" context="{'group_by': 'source_system'}"/>
            </search>
        </field>
    </record>

    <!-- ─── Action ────────────────────────────────────────────────────── -->
    <record id="action_pms_reservation_charge" model="ir.actions.act_window">
        <field name="name">Reservation Charges</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">pms.reservation.charge</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_reservation_charge_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Reservation Charge!
            </p>
            <p>
                Reservation Charges store each financial component of a reservation
                (rent, fees, taxes, expenses) separately for owner settlement calculations.
            </p>
        </field>
    </record>

    <!-- ─── Menu ──────────────────────────────────────────────────────── -->
    <menuitem id="menu_pms_reservation_charge"
              name="Reservation Charges"
              parent="menu_pms_properties_cat"
              action="action_pms_reservation_charge"
              sequence="30"/>

</odoo>