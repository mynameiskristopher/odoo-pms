<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_pms_owner_agreement" model="ir.sequence">
        <field name="name">Owner Agreement Sequence</field>
        <field name="code">pms.owner.agreement</field>
        <field name="prefix">AGR/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_pms_owner_settlement" model="ir.sequence">
        <field name="name">Owner Settlement Sequence</field>
        <field name="code">pms.owner.settlement</field>
        <field name="prefix">STL/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>