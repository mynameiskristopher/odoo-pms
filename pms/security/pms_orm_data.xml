<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ─── Owner Partner Category ──────────────────────────────────── -->
    <record id="partner_category_owner" model="res.partner.category">
        <field name="name">Owner</field>
        <field name="active">True</field>
    </record>

    <!-- ─── Default ORM Pipeline Stages ─────────────────────────────── -->
    <record id="stage_orm_new" model="pms.owner.lead.stage">
        <field name="name">New</field>
        <field name="sequence">10</field>
        <field name="is_won">False</field>
        <field name="is_lost">False</field>
    </record>

    <record id="stage_orm_contacted" model="pms.owner.lead.stage">
        <field name="name">Contacted</field>
        <field name="sequence">20</field>
        <field name="is_won">False</field>
        <field name="is_lost">False</field>
    </record>

    <record id="stage_orm_negotiating" model="pms.owner.lead.stage">
        <field name="name">Negotiating</field>
        <field name="sequence">30</field>
        <field name="is_won">False</field>
        <field name="is_lost">False</field>
    </record>

    <record id="stage_orm_onboarded" model="pms.owner.lead.stage">
        <field name="name">Onboarded</field>
        <field name="sequence">40</field>
        <field name="is_won">True</field>
        <field name="is_lost">False</field>
    </record>

    <record id="stage_orm_inactive" model="pms.owner.lead.stage">
        <field name="name">Inactive</field>
        <field name="sequence">50</field>
        <field name="is_won">False</field>
        <field name="is_lost">True</field>
        <field name="fold">True</field>
    </record>
</odoo>